# Required for deploying the BillSplitter contract.
# Copy to .env and add your wallet private key.
# NEVER commit .env or share your private key.

PRIVATE_KEY=your_wallet_private_key_here

# Gmail SMTP sender configuration for FairySplit split-request alerts
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Tempo confidential wallet support
# Set this to the Fairblock / StableTrust contract deployed for Tempo testnet
NEXT_PUBLIC_TEMPO_STABLETRUST_ADDRESS=your_tempo_stabletrust_contract_address

# Tempo BillSplitter support
# Set this to your BillSplitter deployment on Tempo testnet
NEXT_PUBLIC_TEMPO_BILLSPLITTER_ADDRESS=your_tempo_billsplitter_contract_address
